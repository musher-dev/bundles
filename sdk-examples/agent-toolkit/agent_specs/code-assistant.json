{
  "name": "code-assistant",
  "description": "General-purpose coding assistant with full workspace access.",
  "model": "claude-sonnet-4-6",
  "temperature": 0.2,
  "system_prompt": "prompts/system.md",
  "toolset": "default-tools",
  "skills": [
    "researching-codebases",
    "explaining-architecture"
  ],
  "rules": [
    "output-formatting",
    "code-style"
  ],
  "permissions": {
    "file_read": true,
    "file_write": true,
    "terminal": true,
    "web_search": true
  }
}
